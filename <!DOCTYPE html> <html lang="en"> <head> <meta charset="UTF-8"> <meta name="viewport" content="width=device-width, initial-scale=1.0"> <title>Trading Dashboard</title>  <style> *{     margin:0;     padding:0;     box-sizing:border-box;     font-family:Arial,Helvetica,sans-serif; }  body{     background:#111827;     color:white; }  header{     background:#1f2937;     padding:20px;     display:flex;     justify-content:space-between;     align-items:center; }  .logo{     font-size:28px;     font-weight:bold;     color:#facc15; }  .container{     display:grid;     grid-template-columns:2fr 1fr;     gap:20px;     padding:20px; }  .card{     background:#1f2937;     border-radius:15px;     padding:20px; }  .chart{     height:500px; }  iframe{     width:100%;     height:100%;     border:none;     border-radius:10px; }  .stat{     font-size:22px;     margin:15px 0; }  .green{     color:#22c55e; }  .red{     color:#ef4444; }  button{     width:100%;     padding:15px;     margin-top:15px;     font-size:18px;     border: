<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Trading Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,Helvetica,sans-serif;
}

body{
    background:#111827;
    color:white;
}

header{
    background:#1f2937;
    padding:20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:28px;
    font-weight:bold;
    color:#facc15;
}

.container{
    display:grid;
    grid-template-columns:2fr 1fr;
    gap:20px;
    padding:20px;
}

.card{
    background:#1f2937;
    border-radius:15px;
    padding:20px;
}

.chart{
    height:500px;
}

iframe{
    width:100%;
    height:100%;
    border:none;
    border-radius:10px;
}

.stat{
    font-size:22px;
    margin:15px 0;
}

.green{
    color:#22c55e;
}

.red{
    color:#ef4444;
}

button{
    width:100%;
    padding:15px;
    margin-top:15px;
    font-size:18px;
    border:none;
    border-radius:10px;
    cursor:pointer;
    color:white;
}

.buy{
    background:#22c55e;
}

.sell{
    background:#ef4444;
}

button:hover{
    opacity:.9;
}
</style>

</head>
<body>

<header>
<div class="logo">Trading Dashboard</div>

<div>
Balance: <b>$10,000</b> |
Profit: <span class="green">+$245</span>
</div>
</header>

<div class="container">

<div class="card chart">

<iframe
src="https://s.tradingview.com/widgetembed/?frameElementId=tradingview&symbol=FX:EURUSD&interval=15&theme=dark&style=1&toolbarbg=f1f3f6&hide_top_toolbar=false&hide_legend=false&save_image=false">
</iframe>

</div>

<div>

<div class="card">
<h2>Account</h2>

<div class="stat">Win Rate: <span class="green">74%</span></div>

<div class="stat">Risk: 1%</div>

<div class="stat">Today's P/L:
<span class="green">+$145</span>
</div>

<div class="stat">Open Trades: 2</div>

<button class="buy">BUY</button>
<button class="sell">SELL</button>

</div>

<br>

<div class="card">
<h2>Watchlist</h2>
<p>EUR/USD</p>
<p>GBP/USD</p>
<p>XAU/USD</p>
<p>BTC/USD</p>
<p>NAS100</p>
</div>

</div>

</div>

</body>
</html>